generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum TipeTransaksi {
  KREDIT
  DEBIT
}

model Transaksi {
  id          Int              @id @default(autoincrement())
  tanggal     DateTime         @default(now())
  id_kategori Int?             // <-- Sekarang opsional
  kategori    Kategori?        @relation(fields: [id_kategori], references: [id])
  id_pj       Int?             // <-- Sekarang opsional
  pj          PenanggungJawab? @relation(fields: [id_pj], references: [id])
  nominal     Float            
  keterangan  String?          
  tipe        TipeTransaksi    
  bukti_url   String?          
  created_at  DateTime         @default(now())
}

model Kategori {
  id        Int         @id @default(autoincrement())
  nama      String      @unique
  transaksi Transaksi[]
}

model PenanggungJawab {
  id        Int         @id @default(autoincrement())
  nama      String      @unique
  transaksi Transaksi[]
}

// ==== TABEL BARU PROGJA DANUS ====

model PaidPromote {
  id              Int      @id @default(autoincrement())
  nama_pemesan    String
  tanggal_mulai   DateTime
  tanggal_selesai DateTime
  harga           Float
  status          String   @default("Aktif")
  transaksi_id    Int?     // Menyimpan ID relasi ke tabel Transaksi
  created_at      DateTime @default(now())
}

model Proposal {
  id           Int      @id @default(autoincrement())
  pj_pengantar String
  instansi     String
  status       String   @default("Menunggu")
  nominal_cair Float?
  transaksi_id Int?     // Menyimpan ID relasi ke tabel Transaksi
  created_at   DateTime @default(now())
}